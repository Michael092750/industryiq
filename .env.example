# Copy to .env and fill in. .env is git-ignored (never commit real secrets).

# Secret that unlocks engineer-only debug endpoints (e.g. GET /debug/chunks).
# Leave unset to disable those endpoints entirely (they respond 404).
# Send it as the "X-Debug-Key" header when calling debug endpoints.
DEBUG_API_KEY=change-me-to-a-long-random-string
